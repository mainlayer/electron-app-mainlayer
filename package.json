{
  "name": "electron-app-mainlayer",
  "version": "0.1.0",
  "description": "Desktop app with Electron and in-app Mainlayer payments — license activation, premium feature unlocking",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@mainlayer/sdk": "^1.0.0",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.4",
    "vitest": "^1.4.0",
    "@vitest/coverage-v8": "^1.4.0"
  },
  "build": {
    "appId": "fr.mainlayer.desktop-demo",
    "productName": "Mainlayer Desktop",
    "files": ["dist/**/*"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
